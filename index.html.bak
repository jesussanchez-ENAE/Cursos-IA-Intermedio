<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>La Fábrica de Agentes | ENAE Business School</title>
    <link rel="stylesheet" href="fonts.css">
    <link rel="stylesheet" href="index.css?v=2">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* Specific section styles */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background: linear-gradient(to right, rgba(10,10,10,0.9), rgba(10,10,10,0.5)), url('./Links/portrait-of-smiling-professional-young-man-in-suit-2026-01-05-06-28-34-utc.jpg');
            background-size: cover;
            background-position: center;
            padding-top: 8rem;
        }

        .hero-content {
            flex: 1;
        }

        .hero-form {
            flex: 0 0 400px;
            padding: 2rem 2.2rem;
        }

        .form-group {
            margin-bottom: 1.1rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.35rem;
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--secondary-accent);
        }

        .form-group input {
            width: 100%;
            padding: 0.8rem 1rem;
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            color: white;
            border-radius: 0.5rem;
            font-family: var(--font-body);
        }

        .fundae-badge img {
            max-height: 28px;
            width: auto;
            margin-top: 0.5rem;
        }

        .check-list {
            list-style: none;
            padding: 0;
        }
        
        .check-list li {
            position: relative;
            padding-left: 2rem;
            margin-bottom: 1rem;
            font-size: 1.05rem;
            color: #ccc;
        }

        .check-list li::before {
            content: '✔';
            position: absolute;
            left: 0;
            color: var(--accent-color);
            font-weight: bold;
        }

        .program-list {
            list-style: none;
            padding: 0;
            margin-top: 1.5rem;
        }

        .program-list li {
            position: relative;
            padding-left: 1.5rem;
            margin-bottom: 0.8rem;
            font-size: 0.9rem;
            color: #aaa;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding-bottom: 0.8rem;
        }

        .program-list li:last-child {
            border-bottom: none;
        }

        .program-list li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: var(--accent-color);
            font-family: var(--font-mono);
        }

        /* Comparativa Section Styles */
        .step-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.2rem 1.5rem;
            background: rgba(255, 255, 255, 0.01);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 0.75rem;
            transition: var(--transition);
        }

        .step-card:hover {
            border-color: rgba(168, 23, 48, 0.3);
            transform: translateY(-1px);
            background: rgba(168, 23, 48, 0.02);
        }

        .step-card.teal {
            background: rgba(29, 158, 117, 0.01);
            border-color: rgba(29, 158, 117, 0.08);
        }

        .step-card.teal:hover {
            border-color: rgba(29, 158, 117, 0.3);
            transform: translateY(-1px);
            background: rgba(29, 158, 117, 0.03);
        }

        .step-connector {
            width: 1px;
            height: 16px;
            background: rgba(255, 255, 255, 0.05);
            margin: 0 auto;
        }

        .step-connector.teal {
            background: rgba(29, 158, 117, 0.15);
        }

        .bar-fill {
            height: 100%;
            border-radius: 6px;
            transform-origin: left;
            animation: barIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        /* ── INTERACTIVE CALENDAR ───────────────────────────────────────── */
        .cal-wrap {
            background: #ffffff;
            border-radius: 1.5rem;
            padding: 2rem;
            box-shadow: 0 4px 32px rgba(0,0,0,0.06);
            border: 1px solid rgba(0,0,0,0.06);
        }

        .cal-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
        }

        .cal-header > div {
            text-align: center;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            color: #999;
            padding: 0.5rem 0 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .cal-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            font-family: var(--font-mono);
            color: #aaa;
            border-radius: 8px;
            cursor: default;
            transition: var(--transition);
            user-select: none;
        }

        .cal-day.empty {
            pointer-events: none;
        }

        /* Session day styling */
        .cal-day.cal-session {
            background: var(--accent-color);
            color: #ffffff !important;
            font-weight: 700;
            cursor: pointer;
            text-decoration: underline;
            text-underline-offset: 3px;
            box-shadow: 0 4px 12px rgba(168, 23, 48, 0.3);
            position: relative;
        }

        .cal-day.cal-session:hover {
            transform: scale(1.15);
            box-shadow: 0 6px 20px rgba(168, 23, 48, 0.5);
        }

        .cal-day.cal-session:focus {
            outline: 2px solid var(--accent-color);
            outline-offset: 3px;
        }

        .cal-day.cal-session.active {
            background: #7a0f22;
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(168, 23, 48, 0.6);
        }

        /* Detail panel */
        .cal-detail-wrap {
            background: #ffffff;
            border-radius: 1.5rem;
            padding: 2.5rem;
            min-height: 420px;
            box-shadow: 0 4px 32px rgba(0,0,0,0.06);
            border: 1px solid rgba(0,0,0,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .cal-detail-empty {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
        }

        .cal-detail {
            width: 100%;
            animation: calDetailIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
            align-self: flex-start;
        }

        @keyframes calDetailIn {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .cal-detail-tag {
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--accent-color);
            letter-spacing: 0.15em;
            text-transform: uppercase;
            margin-bottom: 1rem;
            font-weight: 700;
        }

        .cal-detail-title {
            font-family: var(--font-heading);
            font-size: 1.6rem;
            color: #0e0e0e;
            line-height: 1.2;
            margin-bottom: 1rem;
            text-transform: uppercase;
            font-weight: 900;
        }

        .cal-detail-desc {
            font-size: 0.95rem;
            color: #555;
            line-height: 1.7;
            margin-bottom: 1.5rem;
        }

        .cal-detail-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .cal-detail-list li {
            font-size: 0.9rem;
            color: #444;
            padding-left: 1.4rem;
            position: relative;
            line-height: 1.5;
        }

        .cal-detail-list li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: var(--accent-color);
            font-family: var(--font-mono);
        }

        @keyframes barIn {
            from { transform: scaleX(0); }
            to { transform: scaleX(1); }
        }

        /* Footer Custom Styles */
        .footer-social {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .footer-social a {
            color: rgba(255, 255, 255, 0.6);
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .footer-social a svg {
            width: 20px;
            height: 20px;
            stroke-width: 2px;
            display: block;
            transition: var(--transition);
        }

        .footer-social a:hover {
            color: #ffffff;
            border-color: rgba(168, 23, 48, 0.4);
            background: rgba(168, 23, 48, 0.15);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(168, 23, 48, 0.3);
        }

        .footer-links {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.15);
            font-family: var(--font-mono);
            margin-bottom: 2rem;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: #666;
            transition: var(--transition);
        }

        .footer-links a:hover {
            color: white;
        }

        /* ── LIGHT SECTION THEME ─────────────────────────────────────────── */
        .section-light {
            background: #f2efe8 !important;
            border-top: none !important;
        }

        /* Text inversions */
        .section-light h2,
        .section-light h3,
        .section-light h4,
        .section-light span:not(.text-gradient):not(.num):not(.accordion-icon) {
            color: #0e0e0e;
        }

        .section-light p {
            color: #555555;
        }

        /* Accent mono labels keep the brand crimson */
        .section-light [style*="color: var(--accent-color)"],
        .section-light [style*="color:var(--accent-color)"] {
            color: var(--accent-color) !important;
        }

        /* Bento cards go white with a soft shadow */
        .section-light .bento-card {
            background: #ffffff !important;
            border: 1px solid rgba(0, 0, 0, 0.06) !important;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
        }

        .section-light .bento-card::before {
            background: radial-gradient(800px circle at var(--mouse-x, 0px) var(--mouse-y, 0px), rgba(168, 23, 48, 0.07), transparent 40%) !important;
        }

        .section-light .bento-card:hover {
            border-color: rgba(168, 23, 48, 0.3) !important;
            box-shadow: 0 16px 48px rgba(168, 23, 48, 0.1) !important;
        }

        .section-light .bento-card h4 {
            color: #0e0e0e !important;
        }

        .section-light .bento-card p {
            color: #555555 !important;
        }

        /* Glass card in light sections */
        .section-light .glass {
            background: #ffffff !important;
            border-color: rgba(168, 23, 48, 0.2) !important;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1) !important;
        }

        .section-light .glass h3 {
            color: #0e0e0e !important;
        }

        /* Accordion in light sections */
        .section-light .accordion-item {
            border-bottom-color: rgba(0, 0, 0, 0.08);
        }

        .section-light .accordion-trigger {
            color: rgba(0, 0, 0, 0.25);
        }

        .section-light .accordion-trigger .num {
            color: rgba(0, 0, 0, 0.15);
        }

        .section-light .accordion-item.active .accordion-trigger {
            color: #0e0e0e;
        }

        .section-light .accordion-icon {
            color: rgba(0, 0, 0, 0.2);
        }

        /* Session row dividers */
        .section-light .session-row {
            border-bottom-color: rgba(0, 0, 0, 0.08) !important;
        }

        .section-light .session-row span:first-child {
            color: #888 !important;
        }

        .section-light .session-row span:last-child {
            color: #0e0e0e !important;
        }

        /* Text-gradient override for light (use dark-to-mid gradient) */
        .section-light .text-gradient {
            background: linear-gradient(to right, #1a1a1a 0%, #a81730 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0px 2px 6px rgba(168, 23, 48, 0.2));
        }

        /* Comparativa-specific overrides for light */
        .section-light .step-card {
            background: rgba(0,0,0,0.04) !important;
            border-color: rgba(0,0,0,0.08) !important;
        }

        .section-light .step-card:hover {
            border-color: rgba(168, 23, 48, 0.3) !important;
            background: rgba(168, 23, 48, 0.04) !important;
        }

        .section-light .step-card.teal:hover {
            border-color: rgba(29, 158, 117, 0.35) !important;
            background: rgba(29, 158, 117, 0.05) !important;
        }

        /* Step-card text labels */
        .section-light .step-card span[style*="color: #fff"],
        .section-light .step-card span[style*="color:#fff"],
        .section-light .step-card span[style*="color: #ffffff"],
        .section-light .step-card span[style*="color:#ffffff"] {
            color: #1a1a1a !important;
        }

        /* Step connectors */
        .section-light .step-connector {
            background: rgba(0,0,0,0.1) !important;
        }

        .section-light .step-connector.teal {
            background: rgba(29, 158, 117, 0.25) !important;
        }

        /* Bento card header dividers */
        .section-light .bento-card [style*="border-bottom: 1px solid rgba(255,255,255,0.05)"],
        .section-light .bento-card [style*="border-bottom:1px solid rgba(255,255,255,0.05)"] {
            border-bottom-color: rgba(0,0,0,0.08) !important;
        }

        .section-light .bento-card [style*="border-top: 1px solid rgba(255,255,255,0.05)"],
        .section-light .bento-card [style*="border-top:1px solid rgba(255,255,255,0.05)"] {
            border-top-color: rgba(0,0,0,0.08) !important;
        }

        /* Total time label ("17 horas" and "~1 hora") */
        .section-light .bento-card [style*="color: #fff"],
        .section-light .bento-card [style*="color:#fff"],
        .section-light .bento-card [style*="color: #ffffff"],
        .section-light .bento-card [style*="color:#ffffff"],
        .section-light .bento-card [style*="color: white"],
        .section-light .bento-card [style*="color:white"] {
            color: #1a1a1a !important;
        }

        /* Progress bar track background */
        .section-light .bento-card [style*="background: rgba(255,255,255,0.02)"] {
            background: rgba(0,0,0,0.06) !important;
            border-color: rgba(0,0,0,0.1) !important;
        }

        /* Metric mini-cards inside comparativa */
        .section-light .bento-card [style*="background: rgba(255, 255, 255, 0.01)"] {
            background: rgba(0,0,0,0.03) !important;
            border-color: rgba(0,0,0,0.07) !important;
        }

        /* Comparativa footer note divider */
        .section-light p[style*="border-top: 1px solid rgba(255,255,255,0.05)"] {
            border-top-color: rgba(0,0,0,0.1) !important;
            color: #777 !important;
        }

        /* "Con IA" column border */
        .section-light .bento-card[style*="border-color: rgba(29, 158, 117"] {
            border-color: rgba(29, 158, 117, 0.25) !important;
            background: rgba(29, 158, 117, 0.02) !important;
        }
    </style>
</head>
<body>
    <nav class="nav">
        <div class="nav-content">
            <div class="logo">
                <img src="./Links/src/logo_enae.svg" alt="ENAE Business School Logo">
            </div>
            <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false">
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
            </button>
            <div class="nav-links">
                <a href="#riesgo" class="nav-link-item">Impacto</a>
                <a href="#programa" class="nav-link-item">Programa</a>
                <a href="#registro" class="btn btn-primary nav-btn">Solicita Info</a>
            </div>
        </div>
    </nav>

    <header class="hero">
        <div class="container hero-grid">
            <div class="hero-content">
                <div class="hero-label">
                    <span class="line"></span>
                    <span class="text">PROGRAMA AVANZADO DE IA</span>
                </div>
                <h1>
                    LA FÁBRICA <br>
                    <span class="text-gradient">DE AGENTES</span>
                </h1>
                <p>
                    Aprende a crear software y agentes con IA sin programar. <br>
                    <span>Un programa intensivo de ENAE Business School.</span>
                </p>
                <div class="hero-buttons">
                    <a href="#registro" class="btn btn-primary">Solicita información ahora</a>
                    <a href="#riesgo" class="hero-link">
                        VER IMPACTO <span>→</span>
                    </a>
                </div>
            </div>
            <div id="registro" class="hero-form glass">
                <h3>Solicita <br><span>Información</span></h3>
                <form id="lead-form">
                    <div class="form-group">
                        <label>NOMBRE COMPLETO</label>
                        <input type="text" placeholder="Ej. Alex Rivera" required>
                    </div>
                    <div class="form-group">
                        <label>EMAIL CORPORATIVO</label>
                        <input type="email" placeholder="alex@empresa.ai" required>
                    </div>
                    <div class="form-group">
                        <label>CARGO / RESPONSABILIDAD</label>
                        <input type="text" placeholder="Director de Innovación">
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: 0.5rem; margin-top: 1rem; padding: 0.9rem;">Unirme a la Revolución</button>
                </form>
                <div class="fundae-badge">
                    <p>Programa Bonificable por</p>
                    <img src="./Links/src/logo_fundae.svg" alt="Fundae">
                </div>
                <p class="plazas-limitadas">⚠ PLAZAS LIMITADAS POR CONVOCATORIA</p>
            </div>
        </div>
    </header>

    <section id="riesgo">
        <div class="parallax-bg" style="background-image: url('./Links/src/Recurso 2.svg');"></div>
        <div class="container relative-container">
            <div class="section-header">
                <p class="subtitle">LA REALIDAD DEL MERCADO</p>
                <h2>El Impacto de la <br><span class="text-gradient">Automatización</span></h2>
            </div>

            <div class="bento-grid">
                <!-- Market narrative -->
                <div class="bento-card span-7 flex-center-y">
                    <h3>La IA ya está transformando <span class="text-gradient">empresas y procesos</span></h3>
                    <p class="bento-card-desc">
                        La inteligencia artificial está automatizando operaciones complejas y sustituyendo tareas repetitivas a un ritmo sin precedentes.
                    </p>
                    <p class="bento-card-desc secondary">
                        Quedarse atrás significa perder competitividad frente a empresas que ya trabajan con automatización, agentes inteligentes y herramientas de software interno personalizadas.
                    </p>
                </div>

                <!-- Learning List -->
                <div class="bento-card span-5 flex-center-y">
                    <h3 class="bento-card-header">EN ESTE PROGRAMA APRENDERÁS A:</h3>
                    <ul class="check-list">
                        <li>Crear aplicaciones con IA sin escribir código</li>
                        <li>Automatizar procesos de negocio clave</li>
                        <li>Diseñar agentes inteligentes para atención y ventas</li>
                        <li>Conectar la IA con documentos y conocimiento interno</li>
                        <li>Implementar IA real en tus operaciones</li>
                    </ul>
                </div>

                <!-- Timeline Chart.js -->
                <div class="bento-card span-8 chart-card">
                    <div class="chart-header">
                        <h4>Puestos en riesgo de obsolescencia (2024-2035)</h4>
                        <div class="chart-legend">
                            <span><span class="bullet sin-ia"></span>Sin IA</span>
                            <span><span class="bullet con-ia"></span>Con IA</span>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas id="lineChart" role="img" aria-label="Línea de tiempo de riesgo de obsolescencia"></canvas>
                    </div>
                </div>

                <!-- Stats Grid (merged visually inside the bento) -->
                <div class="bento-card span-4 stats-container">
                    <div class="stat-mini-card">
                        <p class="label">Empleos eliminados (2030)</p>
                        <p class="value">92M</p>
                    </div>
                    <div class="stat-mini-card">
                        <p class="label">Trabajadores deben reconvertirse</p>
                        <p class="value">375M</p>
                    </div>
                    <div class="stat-mini-card">
                        <p class="label">Habilidades obsoletas en 2030</p>
                        <p class="value">39%</p>
                    </div>
                </div>

                <!-- Professional Risk Chart.js -->
                <div class="bento-card span-12 chart-card tall-chart-card">
                    <h4>Porcentaje de riesgo de automatización por profesión (2030)</h4>
                    <div class="chart-container tall">
                        <canvas id="barChart" role="img" aria-label="Riesgo de automatización por profesión"></canvas>
                    </div>
                    <p class="chart-footer-note">Fuentes: WEF Future of Jobs Report 2025 · McKinsey Global Institute · PwC Global Workforce. Estimaciones promediadas.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="comparativa" class="section-light">
        <div class="parallax-bg" style="background-image: url('./Links/src/Recurso 2.svg');"></div>
        <div class="container relative-container">
            <!-- Header de la sección -->
            <div class="section-header">
                <p class="subtitle">EFICIENCIA OPERATIVA · CASO REAL</p>
                <h2>Flujo de trabajo <br><span class="text-gradient">Con IA vs Sin IA</span></h2>
            </div>

            <!-- Bento Grid de Comparativa de Columnas -->
            <div class="bento-grid comparative-grid">
                <!-- Columna: Sin IA -->
                <div class="bento-card span-6 comparative-column column-manual">
                    <div>
                        <div class="column-header">
                           <span class="dot"></span>
                           <span class="label">PROCESO MANUAL (SIN IA)</span>
                        </div>
                        <div class="steps-container">
                            <div class="step-card">
                                <span>1. Recopilación de información</span>
                                <span class="time-label">4 h</span>
                            </div>
                            <div class="step-connector"></div>
                            <div class="step-card">
                                <span>2. Limpieza de bases de datos</span>
                                <span class="time-label">3 h</span>
                            </div>
                            <div class="step-connector"></div>
                            <div class="step-card">
                                <span>3. Análisis estadístico y lógica</span>
                                <span class="time-label">5 h</span>
                            </div>
                            <div class="step-connector"></div>
                            <div class="step-card">
                                <span>4. Redacción de informe inicial</span>
                                <span class="time-label">3 h</span>
                            </div>
                            <div class="step-connector"></div>
                            <div class="step-card">
                                <span>5. Revisión final y ajustes</span>
