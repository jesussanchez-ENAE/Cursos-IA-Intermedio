    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script src="main.js?v=2"></script>
    <script>
        // ── Calendar interactivity ─────────────────────────────────────────
        (function () {
            const sessionDays = document.querySelectorAll('.cal-session');
            const empty = document.getElementById('cal-empty');
            let activeSession = null;

            function showDetail(sessionId, clickedEl) {
                // Hide all panels
                document.querySelectorAll('.cal-detail').forEach(el => el.hidden = true);
                // Remove active from all days
                sessionDays.forEach(d => d.classList.remove('active'));

                if (activeSession === sessionId) {
                    // Toggle off
                    empty.style.display = 'flex';
                    activeSession = null;
                    return;
                }

                // Show selected
                const panel = document.getElementById('cal-detail-' + sessionId);
                if (panel) {
                    empty.style.display = 'none';
                    panel.hidden = false;
                    // Re-trigger animation
                    panel.style.animation = 'none';
                    panel.offsetHeight; // reflow
                    panel.style.animation = '';
                    clickedEl.classList.add('active');
                    activeSession = sessionId;
                }
            }

            sessionDays.forEach(function (day) {
                day.addEventListener('click', function () {
                    showDetail(this.dataset.session, this);
                });
                day.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        showDetail(this.dataset.session, this);
                    }
                });
            });
        })();
    </script>
</body>
</html>
